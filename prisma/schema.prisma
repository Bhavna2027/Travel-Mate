  split_type     String?          @default("equal") @db.VarChar(10)
  created_at     DateTime?        @default(now()) @db.Timestamptz(6)
  updated_at     DateTime?        @default(now()) @db.Timestamptz(6)
  expense_splits expense_splits[]
  groups         groups           @relation(fields: [group_id], references: [group_id], onDelete: Cascade, onUpdate: NoAction)
  users          users            @relation(fields: [paid_by], references: [user_id], onDelete: Cascade, onUpdate: NoAction)

