  size            Int
  guide_id        String?           @db.Uuid
  status          String?           @default("forming") @db.VarChar(20)
  matched_at      DateTime?         @db.Timestamptz(6)
  locked_at       DateTime?         @db.Timestamptz(6)
  completed_at    DateTime?         @db.Timestamptz(6)
  archived_at     DateTime?         @db.Timestamptz(6)
  created_at      DateTime?         @default(now()) @db.Timestamptz(6)
  updated_at      DateTime?         @default(now()) @db.Timestamptz(6)
  version         Int?              @default(1)
  bookings        bookings[]
  expenses        expenses[]
  group_members   group_members[]
  destinations    destinations?     @relation(fields: [destination_id], references: [destination_id], onDelete: NoAction, onUpdate: NoAction)
  users           users?            @relation(fields: [guide_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  guide_requests  guide_requests[]
  itineraries     itineraries?
  location_shares location_shares[]
  matches         matches[]
  polls           polls[]
  ratings         ratings[]
  reports         reports[]
  sos_alerts      sos_alerts[]

  @@index([start_date, end_date], map: "idx_groups_date_range")
  @@index([destination], map: "idx_groups_destination")
  @@index([status], map: "idx_groups_status")
}

