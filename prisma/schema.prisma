generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model audit_logs {
  log_id      String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id     String?   @db.Uuid
  action      String    @db.VarChar(50)
  entity_type String    @db.VarChar(50)
  entity_id   String?   @db.Uuid
  changes     Json?
  ip_address  String?   @db.Inet
  user_agent  String?
  metadata    Json?
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  users       users?    @relation(fields: [user_id], references: [user_id], onUpdate: NoAction)

  @@index([entity_type, entity_id], map: "idx_audit_logs_entity")
  @@index([user_id], map: "idx_audit_logs_user")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model bookings {
  booking_id        String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  group_id          String          @db.Uuid
  guide_id          String          @db.Uuid
  guide_request_id  String?         @db.Uuid
  status            String?         @default("pending") @db.VarChar(20)
  amount            Decimal         @db.Decimal(10, 2)
  commission        Decimal         @db.Decimal(10, 2)
  payment_intent_id String?         @db.VarChar(100)
  booked_at         DateTime?       @default(now()) @db.Timestamptz(6)
  confirmed_at      DateTime?       @db.Timestamptz(6)
  completed_at      DateTime?       @db.Timestamptz(6)
  refunded_at       DateTime?       @db.Timestamptz(6)
  version           Int?            @default(1)
  groups            groups          @relation(fields: [group_id], references: [group_id], onDelete: Cascade, onUpdate: NoAction)
  users             users           @relation(fields: [guide_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
  guide_requests    guide_requests? @relation(fields: [guide_request_id], references: [request_id], onUpdate: NoAction)

  @@index([group_id], map: "idx_bookings_group")
  @@index([guide_id], map: "idx_bookings_guide")
  @@index([status], map: "idx_bookings_status")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model consent_records {
  consent_id   String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id      String    @db.Uuid
  consent_type String    @db.VarChar(20)
  granted      Boolean?  @default(true)
  granted_at   DateTime? @default(now()) @db.Timestamptz(6)
  revoked_at   DateTime? @db.Timestamptz(6)
  ip_address   String?   @db.Inet
  created_at   DateTime? @default(now()) @db.Timestamptz(6)
  users        users     @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_consent_records_user")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model destination_template_items {
  item_id        String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  destination_id String       @db.Uuid
  day_number     Int
  title          String       @db.VarChar(200)
  description    String?
  sort_order     Int?         @default(0)
  created_at     DateTime?    @default(now()) @db.Timestamptz(6)
  destinations   destinations @relation(fields: [destination_id], references: [destination_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([destination_id], map: "idx_destination_template_items_dest")
}

model destinations {
  destination_id             String                       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name                       String                       @unique @db.VarChar(100)
  description                String?
  cover_image_url            String?
  is_active                  Boolean?                     @default(true)
  created_at                 DateTime?                    @default(now()) @db.Timestamptz(6)
  updated_at                 DateTime?                    @default(now()) @db.Timestamptz(6)
  destination_template_items destination_template_items[]
  groups                     groups[]
