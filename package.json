    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nodemailer": "^9.0.1",
    "pg": "^8.11.3",
    "razorpay": "^2.9.6",
    "sharp": "^0.35.2",
    "ws": "^8.21.0"
  },
